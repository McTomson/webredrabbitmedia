2) CSS aus app/styleguide/styleguide.css — .rr-btn-draw
------------------------------------------------------------------------

/* ---- 2) Line-Draw-Button (.rr-btn-draw) ----
   Hover: Schrift spreizt, abgerundete Linie zeichnet sich rundum,
   kleine Akzente ziehen ein. Themen ueber --line_color/--back_color. */
.rr .rr-btn-draw {
  position: relative;
  z-index: 0;
  display: inline-block;
  width: 230px;
  height: 56px;
  text-decoration: none;
  font-family: var(--rr-font-ui);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--line_color);
  transition: letter-spacing 0.3s ease, color 0.3s ease;
}
.rr .rr-btn-draw__text {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
  height: 100%;
}
.rr .rr-btn-draw::before,
.rr .rr-btn-draw::after,
.rr .rr-btn-draw__text::before,
.rr .rr-btn-draw__text::after {
  content: "";
  position: absolute;
  height: 3px;
  border-radius: 2px;
  background: var(--line_color);
  transition: width 0.5s ease;
}
.rr .rr-btn-draw::before { top: 0; left: 54px; width: calc(100% - 56px * 2 - 16px); }
.rr .rr-btn-draw::after { top: 0; right: 54px; width: 8px; }
.rr .rr-btn-draw__text::before { bottom: 0; right: 54px; width: calc(100% - 56px * 2 - 16px); }
.rr .rr-btn-draw__text::after { bottom: 0; left: 54px; width: 8px; }
.rr .rr-btn-draw__line { position: absolute; top: 0; width: 56px; height: 100%; overflow: hidden; }
.rr .rr-btn-draw__line::before {
  content: "";
  position: absolute;
  top: 0;
  width: 150%;
  height: 100%;
  box-sizing: border-box;
  border-radius: 300px;
  border: solid 3px var(--line_color);
}
.rr .rr-btn-draw__line:nth-child(1),
.rr .rr-btn-draw__line:nth-child(1)::before { left: 0; }
.rr .rr-btn-draw__line:nth-child(2),
.rr .rr-btn-draw__line:nth-child(2)::before { right: 0; }
.rr .rr-btn-draw:hover { letter-spacing: 6px; }
.rr .rr-btn-draw:hover::before,
.rr .rr-btn-draw:hover .rr-btn-draw__text::before { width: 8px; }
.rr .rr-btn-draw:hover::after,
.rr .rr-btn-draw:hover .rr-btn-draw__text::after { width: calc(100% - 56px * 2 - 16px); }
.rr .rr-btn-draw__drow1,
.rr .rr-btn-draw__drow2 { position: absolute; z-index: -1; border-radius: 16px; transform-origin: 16px 16px; }
.rr .rr-btn-draw__drow1 { top: -16px; left: 40px; width: 32px; height: 0; transform: rotate(30deg); }
.rr .rr-btn-draw__drow2 { top: 44px; left: 77px; width: 32px; height: 0; transform: rotate(-127deg); }
.rr .rr-btn-draw__drow1::before,
.rr .rr-btn-draw__drow1::after,
.rr .rr-btn-draw__drow2::before,
.rr .rr-btn-draw__drow2::after { content: ""; position: absolute; }
.rr .rr-btn-draw__drow1::before { bottom: 0; left: 0; width: 0; height: 32px; border-radius: 16px; transform-origin: 16px 16px; transform: rotate(-60deg); }
.rr .rr-btn-draw__drow1::after { top: -10px; left: 45px; width: 0; height: 32px; border-radius: 16px; transform-origin: 16px 16px; transform: rotate(69deg); }
.rr .rr-btn-draw__drow2::before { bottom: 0; left: 0; width: 0; height: 32px; border-radius: 16px; transform-origin: 16px 16px; transform: rotate(-146deg); }
.rr .rr-btn-draw__drow2::after { bottom: 26px; left: -40px; width: 0; height: 32px; border-radius: 16px; transform-origin: 16px 16px; transform: rotate(-262deg); }
.rr .rr-btn-draw__drow1,
.rr .rr-btn-draw__drow1::before,
.rr .rr-btn-draw__drow1::after,
.rr .rr-btn-draw__drow2,
.rr .rr-btn-draw__drow2::before,
.rr .rr-btn-draw__drow2::after { background: var(--back_color); }
.rr .rr-btn-draw:hover .rr-btn-draw__drow1 { animation: rr-drow1 ease-in 0.06s forwards; }
.rr .rr-btn-draw:hover .rr-btn-draw__drow1::before { animation: rr-drow2 linear 0.08s 0.06s forwards; }
.rr .rr-btn-draw:hover .rr-btn-draw__drow1::after { animation: rr-drow3 linear 0.03s 0.14s forwards; }
.rr .rr-btn-draw:hover .rr-btn-draw__drow2 { animation: rr-drow4 linear 0.06s 0.2s forwards; }
.rr .rr-btn-draw:hover .rr-btn-draw__drow2::before { animation: rr-drow3 linear 0.03s 0.26s forwards; }
.rr .rr-btn-draw:hover .rr-btn-draw__drow2::after { animation: rr-drow5 linear 0.06s 0.32s forwards; }
@keyframes rr-drow1 { 0% { height: 0; } 100% { height: 100px; } }
@keyframes rr-drow2 { 0% { width: 0; opacity: 0; } 10% { opacity: 0; } 11% { opacity: 1; } 100% { width: 120px; } }
@keyframes rr-drow3 { 0% { width: 0; } 100% { width: 80px; } }
@keyframes rr-drow4 { 0% { height: 0; } 100% { height: 120px; } }
@keyframes rr-drow5 { 0% { width: 0; } 100% { width: 124px; } }
.rr .rr-btn-draw--red { --line_color: #f12032; --back_color: #ffe1e5; }
.rr .rr-btn-draw--navy { --line_color: #1c2837; --back_color: #e7ecf5; }
.rr .rr-btn-draw--ink { --line_color: #23262e; --back_color: #efeee9; }

