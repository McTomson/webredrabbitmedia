# Environment Variables für SEO & Auto-Indexierung

# Google Indexing API
# Erstelle einen Service Account in Google Cloud Console
# https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL
NEXT_PUBLIC_SITE_URL=https://web.redrabbit.media

# Contact Form (für API Route)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=office@redrabbit.media
SMTP_PASSWORD=your-app-password
SMTP_FROM=office@redrabbit.media
SMTP_TO=d.pashlov@redrabbit.media,t.uhlir@redrabbit.media

# Geschützte Admin/API-Routen
# Akzeptiert als Authorization: Bearer <token> oder x-api-key: <token>
ADMIN_API_TOKEN=replace-with-long-random-token

# IndexNow
INDEXNOW_API_KEY=replace-with-indexnow-key

# Vercel Analytics (optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Anleitung für Google Service Account:
# 1. Gehe zu https://console.cloud.google.com
# 2. Erstelle ein neues Projekt oder wähle ein bestehendes
# 3. Aktiviere "Web Search Indexing API"
# 4. Erstelle Service Account unter IAM & Admin
# 5. Erstelle JSON Key und kopiere die Werte hierher
# 6. Füge den Service Account als Owner in Google Search Console hinzu
