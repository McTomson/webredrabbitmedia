-4.89 -26.81 -4.89 -26.81 C-8.21 -26.3 -10.77 -23.38 -10.77 -19.87 Z","x":0.3044,"y":0.3993,"rot":-10.81,"sx":1.1956,"sy":-1.1956,"fx":0.0353,"fy":0.1387,"fr":-60.85,"fs":1,"e":0.3333,"a":0.7037},{"d":"M-10.77 -19.87 C-10.77 -14.22 -7.36 -12.76 2.43 -9.76 C16.31 -5.39 22.01 -0.6 22.01 9.68 C22.01 20.56 12.14 27.84 2.09 27.07 C2.09 27.07 2.09 26.9 2.09 26.9 C5.84 26.3 9.07 23.3 9.07 18.93 C9.07 13.36 4.81 11.13 -3.19 8.65 C-16.3 4.54 -22.01 -0.25 -22.01 -10.53 C-22.01 -19.95 -14.59 -27.07 -4.89 -27.07 C-4.89 -27.07 -4.89 -26.81 -4.89 -26.81 C-8.21 -26.3 -10.77 -23.38 -10.77 -19.87 Z","x":0.3597,"y":0.5014,"rot":-81.52,"sx":1.1956,"sy":1.1956,"fx":0.3682,"fy":0.9565,"fr":-144.8,"fs":1,"e":0.3704,"a":0.7407},{"d":"M-13.85 -2.5 C-10.61 -9.44 -5.59 -12.01 1.9 -11.24 C9.82 -10.47 14.58 -3.44 13.81 4.18 C13.81 4.18 -4.06 11.37 -4.06 11.37 C-4.06 11.37 -4.06 11.12 -4.06 11.12 C-0.91 4.78 -1.51 -3.1 -7.55 -4.3 C-10.87 -4.98 -12.74 -3.53 -13.68 -2.42 C-13.68 -2.42 -13.85 -2.5 -13.85 -2.5 Z","x":0.3972,"y":0.2871,"rot":-59.02,"sx":1.1956,"sy":-1.1956,"fx":0.4172,"fy":0.0867,"fr":-183.39,"fs":1,"e":0.4074,"a":0.7778},{"d":"M-13.85 -2.5 C-10.61 -9.44 -5.59 -12.01 1.9 -11.24 C9.82 -10.47 14.58 -3.44 13.81 4.18 C13.81 4.18 -4.06 11.37 -4.06 11.37 C-4.06 11.37 -4.06 11.12 -4.06 11.12 C-0.91 4.78 -1.51 -3.1 -7.55 -4.3 C-10.87 -4.98 -12.74 -3.53 -13.68 -2.42 C-13.68 -2.42 -13.85 -2.5 -13.85 -2.5 Z","x":0.3366,"y":0.492,"rot":120.98,"sx":1.1956,"sy":-1.1956,"fx":0.3136,"fy":0.8578,"fr":68.66,"fs":1,"e":0.4444,"a":0.8148},{"d":"M-13.85 -2.5 C-10.61 -9.44 -5.59 -12.01 1.9 -11.24 C9.82 -10.47 14.58 -3.44 13.81 4.18 C13.81 4.18 -4.06 11.37 -4.06 11.37 C-4.06 11.37 -4.06 11.12 -4.06 11.12 C-0.91 4.78 -1.51 -3.1 -7.55 -4.3 C-10.87 -4.98 -12.74 -3.53 -13.68 -2.42 C-13.68 -2.42 -13.85 -2.5 -13.85 -2.5 Z","x":0.311,"y":0.4436,"rot":146.69,"sx":1.1956,"sy":1.1956,"fx":-0.0057,"fy":0.8318,"fr":228.41,"fs":1,"e":0.4815,"a":0.8519},{"d":"M-13.85 -2.5 C-10.61 -9.44 -5.59 -12.01 1.9 -11.24 C9.82 -10.47 14.58 -3.44 13.81 4.18 C13.81 4.18 -4.06 11.37 -4.06 11.37 C-4.06 11.37 -4.06 11.12 -4.06 11.12 C-0.91 4.78 -1.51 -3.1 -7.55 -4.3 C-10.87 -4.98 -12.74 -3.53 -13.68 -2.42 C-13.68 -2.42 -13.85 -2.5 -13.85 -2.5 Z","x":0.4233,"y":0.3315,"rot":-33.31,"sx":1.1956,"sy":1.1956,"fx":0.62,"fy":0.0992,"fr":-64.09,"fs":1,"e":0.5185,"a":0.8889}];
  const SVGNS="http://www.w3.org/2000/svg";
  const reduced=window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const noHover=window.matchMedia("(hover: none)").matches;
  const clamp=(v,a,b)=>v<a?a:v>b?b:v;
  const lerp=(a,b,t)=>a+(b-a)*t;

  function bezier(p1x,p1y,p2x,p2y){
    const cx=3*p1x, bx=3*(p2x-p1x)-cx, ax=1-cx-bx;
    const cy=3*p1y, by=3*(p2y-p1y)-cy, ay=1-cy-by;
    const fx=t=>((ax*t+bx)*t+cx)*t;
    const fy=t=>((ay*t+by)*t+cy)*t;
    const dfx=t=>(3*ax*t+2*bx)*t+cx;
    return x=>{
      if(x<=0)return 0; if(x>=1)return 1;
      let t=x;
      for(let i=0;i<6;i++){const e=fx(t)-x; if(Math.abs(e)<1e-4)break; const d=dfx(t)||1e-4; t-=e/d;}
      return fy(t);
    };
  }
  const easeMorph=bezier(0.6,0,0.4,1);
  const easeInOut=bezier(0.5,0,0.5,1);
  const GOLDEN=Math.PI*(3-Math.sqrt(5));

  /* ================================================================ */
  /* Haupt-Szene: Elemente                                            */
  /* ================================================================ */
  const sceneMain=document.getElementById("sceneMain");
  const sticky=document.getElementById("mainSticky");
  const htitle=document.getElementById("htitle");
  const hint=document.getElementById("hint");
  const autobtn=sticky.querySelector("[data-auto]");
  const headSvg=document.getElementById("headSvg");
  const textWindow=document.getElementById("textWindow");
  const textMove=document.getElementById("textMove");
  const textCol=sticky.querySelector(".text-col");
  const blobsGroup=sticky.querySelector(".blobs");

  const letterEls=[...htitle.querySelectorAll(".ltr:not(.sp)")];
  letterEls.forEach((el,k)=>{
    const ang=k*GOLDEN+0.7;
    el._dx=Math.cos(ang); el._dy=Math.sin(ang);
    el._dist=0.95+((k*37)%5)/5*0.5;
    el._rot=((k%2)?1:-1)*(70+k*28);
  });
  let udots=[];   /* rote Ue-Punkte: fliegen als eigene Teile mit */
  /* FIX1: spiegelsymmetrischer Scatter — beide Punkte gleiche Weite/dist, dx gespiegelt,
     rot entgegengesetzt -> sie driften nicht auseinander, sondern zerstreuen synchron. */
  const UDOT_P=[{dx:-0.5,dy:-0.87,rot:-150,dist:1.05},{dx:0.5,dy:-0.87,rot:150,dist:1.05}];

  /* ---- Phasen der Haupt-Szene (Fortschritt P: 0..1) ---- */
  const P_REVEAL=0.011;               /* K5: Titel schrumpft ab dem ersten Scroll (~100px); Paint-Reveal nur ganz oben */
  const P_SHRINK1=0.20;
  const P_SCAT0=0.20, P_SCAT1=0.44;   /* Buchstaben fliegen raus (langsamer) */
  const A_A0=0.20, A_A1=0.54;         /* C1: rote Fragmente kommen frueh HEREIN, ueberlappen den Buchstaben-Scatter (0.20-0.44) deutlich */
  const TXT0=0.55, TXT1=0.90;         /* C3: Story-Text startet direkt wenn das letzte Fragment sitzt (Kopf fertig bei A_A1) */
  const DIS0=0.92;                    /* C4: Kopf zerfaellt frueher/laenger -> ueberlappt mit dem Eintritt der Haltungs-Sektion */

  /* ---- Maske + Mal-Zone (Blobs nur OBERHALB der Titel-Oberkante) ---- */
  function fitMask(){
    const r=sticky.getBoundingClientRect();
    const rect=sticky.querySelector(".mrect");
    if(rect){ rect.setAttribute("width",r.width); rect.setAttribute("height",r.height); }
    const pr=document.getElementById("paintRect");
    if(pr){ pr.setAttribute("width",r.width); pr.setAttribute("height",Math.max(60,paintMaxY)); }
  }

  /* ---- Ü-Punkte: Umlaut-Geometrie EINMAL per Canvas messen (Punkt-Groesse, vertikale
     Lage, Mitten-Abstand), dann beide Punkte IDENTISCH und spiegelsymmetrisch um die
     Ink-Mitte des "U" platzieren. So sitzen sie bei jeder Breite exakt und symmetrisch
     ueber dem U, haben gleiche Groesse + gleiches Y und skalieren mit der vw-Schrift mit.
     (Frueher wurden beide Punkte einzeln aus den Pixel-Clustern relativ zur Ink-Kante des
     U gesetzt -> LSB-Versatz + ungleiche Pixelbreiten liessen sie driften/asymmetrisch.) */
  function placeUeDots(){
    const ue=sticky.querySelector(".ue");
    if(!ue) return "no-ue";
    ue.querySelectorAll(".udot").forEach(d=>d.remove());
    const savedT=htitle.style.transform; htitle.style.transform="none";
    const fs=parseFloat(getComputedStyle(htitle).fontSize);
    // Guard: wenn Titel/Font-Layout noch nicht bereit ist (fs NaN/0 -> Canvas-Breite 0
    // -> getImageData wirft und killt den ganzen boot), spaeter erneut versuchen statt crashen.
    if(!isFinite(fs) || fs<=0){ htitle.style.transform=savedT; requestAnimationFrame(placeUeDots); return "retry-fs"; }
    const cv=document.createElement("canvas");
    const ctx=cv.getContext("2d",{willReadFrequently:true});
    const fontSpec="700 "+fs+"px 'DM Sans'";
    ctx.font=fontSpec;
    const m=ctx.measureText("Ü");
    const A=m.fontBoundingBoxAscent, D=m.fontBoundingBoxDescent;
    const pad=6;
    // Breite/Hoehe nie <1 (sonst getImageData IndexSizeError); NaN-Metriken abfangen.
    cv.width=Math.max(2,Math.ceil((isFinite(m.width)?m.width:fs*0.6)+pad*2+fs*0.2));
    cv.height=Math.max(2,Math.ceil((isFinite(A)?A:fs)+(isFinite(D)?D:fs*0.3)+pad*2));
    ctx.font=fontSpec;
    const baseY=Math.ceil(A)+pad;
    ctx.fillStyle="#000";
    ctx.fillText("Ü",pad,baseY);
    const W=cv.width,H=cv.height;
    const px=ctx.getImageData(0,0,W,H).data;
    const solid=(x,y)=>px[(y*W+x)*4+3]>60;
    // oberstes zusammenhaengendes Pixelband = die beiden Umlaut-Punkte
    let dotTop=-1,dotBottom=-1;
    for(let yy=0;yy<H;yy++){
      let has=false;
      for(let xx=0;xx<W;xx++){ if(solid(xx,yy)){has=true;break;} }
      if(has){ if(dotTop<0)dotTop=yy; dotBottom=yy; }
      else if(dotTop>=0) break;
    }
    if(dotTop<0){ htitle.style.transform=savedT; return "no-pixels"; }
    // Spalten-Cluster innerhalb des Punkt-Bands -> zwei Punkte
    const cols=[];
    for(let xx=0;xx<W;xx++){
      let has=false;
      for(let yy=dotTop;yy<=dotBottom;yy++){ if(solid(xx,yy)){has=true;break;} }
      cols.push(has);
    }
    const clusters=[]; let start=-1;
    for(let xx=0;xx<=W;xx++){
      const has=xx<W&&cols[xx];
      if(has&&start<0)start=xx;
      if(!has&&start>=0){ clusters.push([start,xx-1]); start=-1; }
    }
    if(clusters.length<2){ htitle.style.transform=savedT; return "clusters="+clusters.length; }
    const [c0,c1]=clusters.slice(0,2);
    // Punkt-Geometrie in Canvas-Pixeln (skaliert mit fs). Beide Punkte werden IDENTISCH.
    const EXPAND=Math.max(1.5,fs*0.005);
    const dw=Math.max(c0[1]-c0[0]+1, c1[1]-c1[0]+1)+EXPAND*2;   // gemeinsame Breite
    const dh=(dotBottom-dotTop+1)+EXPAND*2;                     // gemeinsame Hoehe
    const sep=((c1[0]+c1[1])/2)-((c0[0]+c0[1])/2);             // Abstand der Punkt-Mitten
    const bandCenY=(dotTop+dotBottom)/2;                        // vertikale Punkt-Mitte (Canvas)
    // Ink-Geometrie des "U" auf dem Bildschirm
    const range=document.createRange();
    range.selectNodeContents(ue);
    const rect=range.getBoundingClientRect();
    let baselineScreen;
    if(Math.abs(rect.height-(A+D))<3){ baselineScreen=rect.top+A; }
    else{ baselineScreen=rect.top+(rect.height-(A+D))/2+A; }
    const ueBox=ue.getBoundingClientRect();
    const Uc=rect.left+rect.width/2;                 // horizontale Ink-Mitte des U
    const cy=baselineScreen-(baseY-bandCenY);        // gemeinsames vertikales Zentrum
    // beide Punkte spiegelsymmetrisch links/rechts der U-Mitte
    [-sep/2, sep/2].forEach(off=>{
      const cx=Uc+off;
      const d=document.createElement("i");
      d.className="udot";
      d.style.left=(cx-dw/2-ueBox.left)+"px";
      d.style.top=(cy-dh/2-ueBox.top)+"px";
      d.style.width=dw+"px";
      d.style.height=dh+"px";
      ue.appendChild(d);
    });
    htitle.style.transform=savedT;
    udots=[...ue.querySelectorAll(".udot")];
    return "ok";
  }

  /* ---- Titel-Geometrie: Schnittkante an der BASISLINIE + Schrumpf-Ziel ---- */
  let tyCut=0, boxCenterY=0, capCenterOff=0, capH=100, vpCenterY=0, sT=0.4, paintMaxY=400;
  function computeShifts(){
    const savedT=htitle.style.transform; htitle.style.transform="none";
    // Mobil (<768): Titel exakt auf Bildschirmbreite fitten. Das Titelwort
    // variiert je Unterseite ("Kontakt" 3.3em, "Ueber uns" laenger) — eine
    // fixe vw-Groesse crop entweder seitlich oder wird winzig. Der Fit ist
    // generisch: CSS-Basisgroesse messen, auf 96vw skalieren, in px setzen.
    if(window.innerWidth<768){
      htitle.style.fontSize="";
      const bw=htitle.getBoundingClientRect().width;
      const base=parseFloat(getComputedStyle(htitle).fontSize);
      if(bw>0&&isFinite(base)&&base>0) htitle.style.fontSize=(base*0.96*window.innerWidth/bw)+"px";
    } else { htitle.style.fontSize=""; }
    const fs=parseFloat(getComputedStyle(htitle).fontSize);
    const cv=document.createElement("canvas");
    const ctx=cv.getContext("2d");
    ctx.font="700 "+fs+"px 'DM Sans'";
    const mU=ctx.measureText("U");
    capH=mU.actualBoundingBoxAscent;
    const A=mU.fontBoundingBoxAscent, D=mU.fontBoundingBoxDescent;
    const box=htitle.getBoundingClientRect();
    let baselineY;
    if(Math.abs(box.height-(A+D))<3){ baselineY=box.top+A; }
    else{ baselineY=box.top+(box.height-(A+D))/2+A; }
    const sr=sticky.getBoundingClientRect();
    // K1: Titel-Anschnitt beim Laden — nur ~67% der Versalhoehe sichtbar, der Rest
    // (untere ~33%) liegt unter der Viewport-Unterkante (Ziel: refs 57_titel_crop_ziel).
    // Mobil (schmal): mehr vom Titel zeigen — 100dvh-Anschnitt + kleiner
    // vw-Font liessen sonst fast nur Weiss sehen ("Haelfte von Kontakt sichtbar").
    const VIS=window.innerWidth<768?0.8:0.67;
    tyCut=(sr.top+sr.height)-baselineY + capH*(1-VIS);
    boxCenterY=box.top+box.height/2;
    capCenterOff=(baselineY-capH/2)-boxCenterY;
    vpCenterY=sr.top+sr.height/2;
    const target=window.innerWidth<768?56:84;
    sT=clamp(target/capH,0.05,1);
    // K2: weiche Mal-Grenze — reicht bis knapp in den Titel-Oberrand hinein.
    // Kein harter Clip mehr; die Begrenzung passiert allein ueber die Spawn-Position
    // (Blob-Mittelpunkte nur oberhalb paintMaxY) -> der Gooey-Blur erzeugt eine
    // organische, weiche Unterkante statt einer geraden Schnittlinie.
    const capTopViewport=(baselineY+tyCut)-capH-(sr.top);
    paintMaxY=clamp(capTopViewport+capH*0.20,60,sr.height);
    htitle.style.transform=savedT;
  }
  const tyCenter=s=>vpCenterY-boxCenterY-capCenterOff*s;

  /* ---- Cursor-Punkt: bleibt IMMER klein ---- */
  const DOTR=9.5;
  function dotCtl(){
    const el=sticky.querySelector(".cursor-dot");
    const S=19;
    return {
      move(x,y){ el.style.transform="translate("+(x-S/2)+"px,"+(y-S/2)+"px)"; },
      show(){ el.style.opacity="1"; },
      hide(){ el.style.opacity="0"; }
    };
  }

  /* ---- Reveal: Punkt klein, Pinselstrich waechst dahinter ---- */
  let heroFeed=null, heroFeedEnd=null, painting=true;
  function initFluid(){
    const group=blobsGroup;
    const dot=dotCtl();
    const mouse={x:0,y:0,sx:0,sy:0,diff:0,has:false,init:false};
    const particles=[];
    const GROW=430, HOLD=2500;
    const LIFE=GROW+HOLD+1700;

    class Particle{
      constructor(x,y,base){
        this.base=Math.max(30,Math.min(base,92));
        this.born=performance.now();
        this.life=LIFE+Math.random()*400;
        this.el=document.createElementNS(SVGNS,"circle");
        this.el.setAttribute("cx",x);this.el.setAttribute("cy",y);
        this.el.setAttribute("r",DOTR);this.el.setAttribute("fill","#000");
        group.appendChild(this.el);
      }
      update(now){
        const age=now-this.born;
        if(age>=this.life)return false;
        let env;
        if(age<GROW){ env=Math.pow(age/GROW,0.6); }
        else if(age<GROW+HOLD){ env=1+0.1*((age-GROW)/HOLD); }
        else{ env=1.1*Math.pow(1-(age-GROW-HOLD)/(this.life-GROW-HOLD),1.7); }
        this.el.setAttribute("r",(DOTR+(this.base-DOTR)*env).toFixed(1));
        return true;
      }
      kill(){ this.el.remove(); }
    }
    function setXY(e){
      if(!painting) return;
      const r=sticky.getBoundingClientRect();
      mouse.x=e.clientX-r.left; mouse.y=e.clientY-r.top;
      if(!mouse.init){ mouse.sx=mouse.x; mouse.sy=mouse.y; mouse.init=true; }
      mouse.has=true; dot.show();
    }
    sticky.addEventListener("pointerenter",setXY);
    sticky.addEventListener("pointermove",setXY);
    sticky.addEventListener("pointerleave",()=>{ mouse.has=false; dot.hide(); });
    /* Touch: pointermove stirbt beim Scroll-Pan (pointercancel), touchmove
       NICHT (passive Listener) -> am Handy malt der Finger, waehrend die Seite
       normal weiterscrollt. Gleiche setXY-Pipeline wie die Maus. */
    sticky.addEventListener("touchstart",e=>{ if(e.touches[0]) setXY(e.touches[0]); },{passive:true});
    sticky.addEventListener("touchmove",e=>{ if(e.touches[0]) setXY(e.touches[0]); },{passive:true});
    sticky.addEventListener("touchend",()=>{ mouse.has=false; dot.hide(); });
    sticky.addEventListener("touchcancel",()=>{ mouse.has=false; dot.hide(); });

    function loop(now){
      if(!sceneMain.isConnected){ return; }
      if(mouse.has&&painting){
        mouse.sx+=(mouse.x-mouse.sx)*0.16;
        mouse.sy+=(mouse.y-mouse.sy)*0.16;
        dot.move(mouse.sx,mouse.sy);
        mouse.diff=Math.hypot(mouse.x-mouse.sx,mouse.y-mouse.sy);
        if(mouse.diff>0.6 && mouse.sy<=paintMaxY){   /* K2: keine Blob-Zentren unterhalb der weichen Grenze */
          particles.push(new Particle(mouse.sx,mouse.sy,mouse.diff*1.5+34));
        }
      }
      for(let i=particles.length-1;i>=0;i--){
        if(!particles[i].update(now)){ particles[i].kill(); particles.splice(i,1); }
      }
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);

    heroFeed=(nx,ny,speed)=>{
      if(!painting) return;
      const r=sticky.getBoundingClientRect();
      mouse.has=true; mouse.init=true;
      mouse.sx=nx*r.width; mouse.sy=ny*r.height;
      mouse.x=mouse.sx; mouse.y=mouse.sy;
      dot.move(mouse.sx,mouse.sy); dot.show();
      if(mouse.sy<=paintMaxY){ particles.push(new Particle(mouse.sx,mouse.sy,speed*1.5+34)); }
    };
    heroFeedEnd=()=>{ mouse.has=false; dot.hide(); };
  }

  let autoRunning=false;
  function runAuto(btn){
    if(reduced||!heroFeed||autoRunning||!painting) return;
    autoRunning=true;
    if(btn){btn.disabled=true;btn.textContent="Läuft …";}
    const paths=[
      [[0.10,0.30],[0.45,0.38],[0.82,0.28]],
      [[0.86,0.52],[0.55,0.44],[0.16,0.55]],
      [[0.30,0.18],[0.5,0.4],[0.7,0.6]]
    ];
    const START=performance.now(), DUR=1000, GAP=250;
    let prev={x:0,y:0};
    function step(now){
      let done=true;
      paths.forEach((pts,i)=>{
        const t0=START+i*(DUR+GAP);
        const t=(now-t0)/DUR;
        if(t<0){done=false;return;}
        if(t>1)return;
        done=false;
        const seg=(pts.length-1)*t;
        const si=Math.min(Math.floor(seg),pts.length-2);
        const f=seg-si;
        const a=pts[si],b=pts[si+1];
        const nx=a[0]+(b[0]-a[0])*f, ny=a[1]+(b[1]-a[1])*f;
        const r=sticky.getBoundingClientRect();
        const speed=Math.hypot((nx-prev.x)*r.width,(ny-prev.y)*r.height)*0.4+22;
        prev={x:nx,y:ny};
        heroFeed(nx,ny,speed);
      });
      if(!done) requestAnimationFrame(step);
      else{ if(heroFeedEnd)heroFeedEnd(); autoRunning=false; if(btn){btn.disabled=false;btn.textContent="Auto abspielen";} }
    }
    requestAnimationFrame(step);
  }

  /* ================================================================ */
  /* Kopf: echte comp5-Fragmente, Start IMMER ausserhalb des Viewports */
  /* ================================================================ */
  const VB={x:116,y:126,w:879,h:788};
  /* Punkt5: KEIN aufgesetzter Ink-Balken mehr. Fragment 27 (das an der Augenposition
     das echte Fragment 26 verdeckte) wird ganz entfernt; stattdessen ist Fragment 26 —
     das ohnehin an der Augenregion sitzt — das EINE Navy-Auge (#1c2837, natuerlicher
     Teil der roten Fragment-Collage, nichts aufgesetzt, nichts verdeckt). Navy ist der
     dunkle Marken-Akzent; das Panel-Blau #0a72a0 bleibt der Kundenliste vorbehalten. */
  /* Navy-Auge = Fragment mit dem groessten Seitenverhaeltnis (max-aspect), EXAKT wie
     relaunch-preview/HomeMorph (asp = max(W/H,H/W), W=w*|sx|, H=h*|sy|). Fuer comp5
     deterministisch verifiziert: Index 1 (der senkrechte Balken). KEIN Fragment wird
     versteckt (echtes hidden=[] in der Maschine; das alte HIDE={27} war eine Erfindung). */
  const EYE=75;
  const P=COMP5.map((p,i)=>{
    const g=document.createElementNS(SVGNS,"g");
    const path=document.createElementNS(SVGNS,"path");
    path.setAttribute("d",p.d);
    path.setAttribute("fill", i===EYE?"#1c2837":"#f12032");
    g.appendChild(path);
    headSvg.appendChild(g);
    let e2=p.e, a2=p.a;
    if(a2-e2<1e-3){ e2=0.02+(i%5)*0.03; a2=e2+0.35; }
    return {
      g,
      tx:p.x*1920, ty:p.y*1080, rot:p.rot, sx:p.sx, sy:p.sy,
      fx:p.fx*1920, fy:p.fy*1080, fr:p.fr, fscale:p.fs,
      e2, a2, ox:p.fx*1920, oy:p.fy*1080,
      eye:i===EYE
    };
  });

  /* C1/C3: Einflug-Zeiten auf [0,1] spreizen -> das erste Fragment startet bei aA=0
     (frueh, waehrend die Buchstaben noch verstreuen), das letzte sitzt exakt bei aA=1
     (Kopf fertig -> Story-Text startet direkt bei TXT0=A_A1). */
  (function normalizeEntry(){
    let eMin=Infinity,aMax=-Infinity;
    for(const q of P){ if(q.e2<eMin)eMin=q.e2; if(q.a2>aMax)aMax=q.a2; }
    const span=(aMax-eMin)||1;
    for(const q of P){ q.e2=(q.e2-eMin)/span; q.a2=(q.a2-eMin)/span; }
  })();

  /* Punkt5: das Navy-Augen-Fragment in der Z-Reihenfolge nach ganz oben heben,
     damit es im fertigen Kopf sichtbar bleibt (nichts deckt es zu, nichts aufgesetzt). */
  P.forEach((q)=>{ if(q.eye) headSvg.appendChild(q.g); });

  /* Offscreen-Startpunkte: Slot in Original-Einflugrichtung bis ueber den
     Viewport-Rand verlaengert (Viewport in viewBox-Koordinaten). */
  function measureHeadStarts(){
    const r=headSvg.getBoundingClientRect();
    if(r.width<10||r.height<10) return;
    const s=Math.min(r.width/VB.w, r.height/VB.h);
    const cx0=r.left+(r.width-VB.w*s)/2 - VB.x*s;
    const cy0=r.top+(r.height-VB.h*s)/2 - VB.y*s;
    const xMin=(0-cx0)/s, xMax=(window.innerWidth-cx0)/s;
    const yMin=(0-cy0)/s, yMax=(window.innerHeight-cy0)/s;
    const diag=Math.hypot(xMax-xMin,yMax-yMin);
    P.forEach((q,i)=>{
      let dx=q.fx-q.tx, dy=q.fy-q.ty;
      if(Math.hypot(dx,dy)<1){ const a=i*GOLDEN; dx=Math.cos(a); dy=Math.sin(a); }
      const len=Math.hypot(dx,dy); dx/=len; dy/=len;
      const tx0=dx>1e-6?(xMax-q.tx)/dx:dx<-1e-6?(xMin-q.tx)/dx:Infinity;
      const ty0=dy>1e-6?(yMax-q.ty)/dy:dy<-1e-6?(yMin-q.ty)/dy:Infinity;
      const t=Math.max(0,Math.min(tx0,ty0))+diag*0.02+40;  /* K6: Start knapp ausserhalb -> Fragmente fliegen frueh sichtbar herein */
      q.ox=q.tx+dx*t; q.oy=q.ty+dy*t;
    });
  }

  function renderHead(aA,bB){
    for(const q of P){
      let cx,cy,rot,sc;
      if(bB>0){
        const startB=(1-q.a2)*0.4;
        const t=clamp((bB-startB)/0.6,0,1);
        const e=easeMorph(t);
        cx=q.tx+(q.ox-q.tx)*e;
        cy=q.ty+(q.oy-q.ty)*e;
        rot=q.rot+(q.fr-q.rot)*e;
        sc=1+(q.fscale-1)*e;
      } else {
        const t=clamp((aA-q.e2)/(q.a2-q.e2),0,1);
        const e=easeMorph(t);
        cx=q.ox+(q.tx-q.ox)*e;
        cy=q.oy+(q.ty-q.oy)*e;
        rot=q.fr+(q.rot-q.fr)*e;
        sc=q.fscale+(1-q.fscale)*e;
      }
      q.g.setAttribute("transform","translate("+cx.toFixed(1)+" "+cy.toFixed(1)+") rotate("+rot.toFixed(2)+") scale("+(q.sx*sc).toFixed(3)+" "+(q.sy*sc).toFixed(3)+")");
    }
  }

  /* ---- Story-Text (laeuft erst NACH dem fertigen Kopf) ---- */
  let winH=0, blockH=0, startY=0, endY=0;
  const textMoveBlocks=[...textMove.children];
  function measureStory(){
    winH=textWindow.clientHeight;
    blockH=textMove.scrollHeight;
    startY=winH;
    endY=-blockH;
  }
  function applyStoryText(sp){
    const ty=startY+(endY-startY)*sp;
    textMove.style.transform="translateY("+ty.toFixed(1)+"px)";
    const wr=textWindow.getBoundingClientRect();
    const wc=wr.top+winH/2;
    for(const b of textMoveBlocks){
      const r=b.getBoundingClientRect();
      const c=r.top+r.height/2;
      const d=Math.abs(c-wc)/(winH*0.5);
      const o=d<1?1:Math.max(0.3,1-(d-1)*0.85);
      b.style.opacity=o.toFixed(2);
    }
  }

  /* ================================================================ */
  /* Haupt-Choreografie                                               */
  /* ================================================================ */
  let lastPainting=true;
  function applyMain(Pm){
    // Titel: Anschnitt (Basislinie) -> Aufstieg+Schrumpf -> klein mittig
    let s, ty;
    if(Pm<=P_REVEAL){ s=1; ty=tyCut; }
    else if(Pm<=P_SHRINK1){
      const r=easeInOut((Pm-P_REVEAL)/(P_SHRINK1-P_REVEAL));
      s=lerp(1,sT,r);
      ty=lerp(tyCut,tyCenter(sT),r);
    } else { s=sT; ty=tyCenter(sT); }
    htitle.style.transform="translateY("+ty.toFixed(1)+"px) scale("+s.toFixed(4)+")";

    // Buchstaben fliegen RAUS (kein blosses Fading), Ue-Punkte als eigene Teile
    const sc=clamp((Pm-P_SCAT0)/(P_SCAT1-P_SCAT0),0,1);
    const R=Math.max(window.innerWidth,window.innerHeight)*0.9;  /* K6: kuerzerer Flugweg -> Buchstaben bleiben laenger sichtbar, Ueberlappung mit Fragment-Einflug deutlicher */
    if(sc<=0){
      for(const el of letterEls){ el.style.transform="none"; }
      for(const d of udots){ d.style.transform=d.style.transform?"":d.style.transform; d.style.transform=""; }
    } else {
      const e=easeMorph(sc);
      for(const el of letterEls){
        const tx=el._dx*el._dist*R*e/s;
        const tyl=el._dy*el._dist*R*e/s;
        el.style.transform="translate("+tx.toFixed(1)+"px,"+tyl.toFixed(1)+"px) rotate("+(el._rot*e).toFixed(1)+"deg)";
      }
      udots.forEach((d,i)=>{
        const q=UDOT_P[i]||UDOT_P[0];
        const tx=q.dx*q.dist*R*e/s, tyd=q.dy*q.dist*R*e/s;
        d.style.transform="translate("+tx.toFixed(1)+"px,"+tyd.toFixed(1)+"px) rotate("+(q.rot*e).toFixed(1)+"deg)";
      });
    }

    // Reveal-Fade + Interaktion (viewport-fix; faded beim Verlassen des Heros)
    const fade=clamp((Pm-P_REVEAL)/0.07,0,1);
    blobsGroup.setAttribute("opacity",(1-fade).toFixed(3));
    const nowPainting=Pm<P_REVEAL+0.01;
    if(nowPainting!==lastPainting){
      lastPainting=nowPainting;
      painting=nowPainting;
      sticky.classList.toggle("painting",nowPainting);
      if(!nowPainting&&heroFeedEnd)heroFeedEnd();
    }
    hint.style.opacity=(fade>0?0:0.55);
    autobtn.style.opacity=(1-fade).toFixed(2);
    autobtn.style.pointerEvents=fade>0.5?"none":"auto";

    // Kopf-Aufbau (alle Fragmente von ausserhalb des Viewports)
    const aA=clamp((Pm-A_A0)/(A_A1-A_A0),0,1);
    const bB=Pm>DIS0?(Pm-DIS0)/(1-DIS0):0;
    // Die roten Ue-Punkte des Wortes "ueber uns" blenden aus, sobald sich der Kopf
    // bildet (relaunch-preview hat kein Ue -> kein Streupunkt ueber dem Kopf).
    for(const d of udots){ d.style.opacity=(1-clamp(aA/0.5,0,1)).toFixed(3); }
    // Kopf erst mit Beginn des Scatterns einblenden -> keine Fragmente im Ruhezustand
    // (bei schmalem/mobilem Viewport lagen sonst ein paar Start-Slots knapp im Bild).
    // FIX2: KEIN Deckkraft-Verblassen mehr. Der Kopf bleibt voll deckend (Rot #f12032 satt,
    // Navy-Auge solide), solange er im Bild ist. Das fruehere headOut (opacity 1 -> 0 waehrend
    // bB) liess ihn blass-rosa/grau ausbleichen. Der Kopf scrollt jetzt nur noch AUS dem Bild
    // (renderHead(bB) laesst die Fragmente deckend nach aussen fliegen), verblasst aber nicht
    // an Ort und Stelle. headIn = reines Eintritts-Gate (leere Buehne vor dem Scatter).
    const headIn=clamp((Pm-P_SCAT0)/0.05,0,1);
    headSvg.style.opacity=headIn.toFixed(3);
    renderHead(aA,bB);
    // Fortschritt fuer die echte Skulptur (MorphSculpture): Einflug (aA 0->1) -> Halten
    // (0.55) -> Aufloesen (bB 0->1 -> progress 1). MorphSculpture liest window.__sculptProgress.
    window.__sculptProgress = bB>0 ? 0.55 + bB*0.45 : aA*0.55;

    // Story-Text erst NACH fertigem Kopf
    const sp=clamp((Pm-TXT0)/(TXT1-TXT0),0,1);
    applyStoryText(sp);
    textCol.style.pointerEvents=(Pm>TXT0-0.03&&Pm<TXT1+0.03)?"auto":"none";
  }

  /* ================================================================ */
  /* SEKTION 4 — Haltungs-Statements                                  */
  /* ================================================================ */
  const sceneBelief=document.getElementById("sceneBelief");
  const beliefSticky=sceneBelief.querySelector(".belief-sticky");
  const stmts=[...sceneBelief.querySelectorAll(".stmt")];
  const bCta=document.getElementById("bCta");
  const B_CENTERS=[0.13,0.37,0.61,0.85], B_W=0.24;
  const smooth=t=>{t=clamp(t,0,1);return t*t*(3-2*t);};
  // R4: gemessene Satzhoehen -> Kontakt-Abstand ist eine leichte Beruehrung (~10% Ueberlappung),
  // kein vollflaechiges Uebereinander. In boot()/resize gefuellt.
  function measureStmts(){
    stmts.forEach(el=>{
      const prev=el.style.transform, po=el.style.opacity;
      el.style.transform="translate(-50%,-50%)"; el.style.opacity="0";
      el._h=el.getBoundingClientRect().height;
      el.style.transform=prev; el.style.opacity=po;
    });
  }
  // R4: Sticky-Stups-Mechanik. Jeder Satz "besitzt" ein Slot von einem halben Nachbar-
  // abstand (|d|<=0.5). Innerhalb der Haltezone (|d|<=HOLD) steht er zentral und voll
  // lesbar; genau EIN Satz ist so zentral. Nur am Slot-Rand (HOLD..EDGE) beruehren sich
  // der wegziehende und der von unten aufsteigende Satz KURZ und LEICHT (~10%), danach
  // faehrt der alte verblassend nach oben raus. Ausserhalb (|d|>EDGE+FADE) unsichtbar ->
  // NIE drei Saetze gleichzeitig, nie vollflaechiges Uebereinander.
  const B_HOLD=0.34, B_EDGE=0.5, B_FADE=0.12;
  function applyBelief(bp){
    const vh=window.innerHeight;
    // C4: Sektion blendet ueber die erste Scroll-Strecke langsam ein, waehrend der
    // Kopf (scene-main) noch zerfaellt -> ueberlappender Uebergang.
    if(beliefSticky){ beliefSticky.style.opacity=clamp(bp/0.07,0,1).toFixed(3); }
    const EXIT=vh*0.62;   // nach oben ganz aus dem Bild
    const PARK=vh*0.42;   // unter dem Bild wartend
    for(let i=0;i<stmts.length;i++){
      const el=stmts[i];
      let d=(B_CENTERS[i]-bp)/B_W;   // d>0: noch unter der Mitte (kommt von unten); d<0: ueber der Mitte (raus)
      if(i===3) d=Math.max(d,0);     // Pointe wird nie nach oben rausgestupst, bleibt zuletzt zentral
      const ad=Math.abs(d), sgn=d<0?-1:1;   // sgn=+1: unten, sgn=-1: oben
      const touch=(el._h||vh*0.24)*0.45;    // Beruehrungsversatz am Slot-Rand -> ~10% Ueberlappung
      let y,o;
      if(ad<=B_HOLD){ y=0; o=1; }                         // zentral gehalten, voll lesbar
      else if(ad<=B_EDGE){                                // leichtes Anstupsen am Slot-Rand
        const k=smooth((ad-B_HOLD)/(B_EDGE-B_HOLD));
        y=sgn*k*touch; o=1;
      } else if(ad<=B_EDGE+B_FADE){                       // raus (oben) bzw. rein-verblassen (unten)
        const m=smooth((ad-B_EDGE)/B_FADE);
        const far=sgn<0?EXIT:PARK;
        y=sgn*(touch+(far-touch)*m); o=1-m;
      } else { y=sgn*(sgn<0?EXIT:PARK); o=0; }            // ausserhalb: unsichtbar geparkt
      el.style.transform="translate(-50%,-50%) translateY("+y.toFixed(1)+"px)";
      el.style.opacity=o.toFixed(3);
    }
    const cp=clamp((bp-(B_CENTERS[3]+0.05))/0.08,0,1);
    const ce=easeInOut(cp);
    bCta.style.opacity=ce.toFixed(3);
    bCta.style.transform="translateY("+((1-ce)*28).toFixed(1)+"px)";
    bCta.style.pointerEvents=cp>0.6?"auto":"none";
  }

  /* ================================================================ */
  /* SEKTION 5 — Partner-Raster mit Tipp-Animation                    */
  /* ================================================================ */
  const scenePartner=document.getElementById("scenePartner");
  /* GENAU diese 13 verifizierten Kundennamen (feste Reihenfolge, exakte Schreibweise).
     Es gibt keinen Ersatz-Pool: die 13 Namen sind IMMER sichtbar. Die Tipp-Animation
     schreibt eine Zelle neu, indem sie den EIGENEN Namen loescht und wieder tippt
     (roter Cursor, max. 2 Zellen gleichzeitig) — nie erscheint ein anderer/doppelter Name.
     Reihenfolge = 3x3-Block (0-8) + untere Reihe (9-12), passend zum Grid. */
  const POOL=["SIGNA","6B47","Tillmann & Kraus","MBT","Sans Souci","Die Vorsorgewohnungs GmbH","Phils.place","Auritas","Almtal Invest","Therme Warten","Lashes by Danesh","ReRo Heizsysteme","K2 Dach- & Bau"];
  const cells=[...document.querySelectorAll("#pGrid .p-cell:not(.p-cta)")].map(c=>({
    el:c, name:c.querySelector(".p-name"), cur:"", state:"idle", t0:0, target:""
  }));
  function initCells(){
    cells.forEach((c,i)=>{ c.cur=POOL[i%POOL.length]; c.name.textContent=c.cur; });
  }
  let nextLaunch=1500, rrIndex=0;
  const DEL_MS=42, TYPE_MS=78, PAUSE_MS=320;
  function partnerTick(now){
    if(reduced) return;
    const r=scenePartner.getBoundingClientRect();
    if(r.bottom<0||r.top>window.innerHeight) return;
    let active=0;
    for(const c of cells) if(c.state!=="idle") active++;
    if(active<2&&now>nextLaunch){
      for(let k=0;k<cells.length;k++){
        const c=cells[(rrIndex+k)%cells.length];
        if(c.state==="idle"){
          rrIndex=(rrIndex+k+1)%cells.length;
          c.state="del"; c.t0=now;
          c.target=c.cur;               /* eigenen Namen neu tippen (kein Fremdname) */
          c.el.classList.add("typing");
          break;
        }
      }
      nextLaunch=now+2600+Math.random()*1600;
    }
    for(const c of cells){
      if(c.state==="del"){
        const n=Math.max(0,c.cur.length-Math.floor((now-c.t0)/DEL_MS));
        c.name.textContent=c.cur.slice(0,n);
        if(n===0){ c.state="pause"; c.t0=now; }
      } else if(c.state==="pause"){
        if(now-c.t0>PAUSE_MS){ c.state="type"; c.t0=now; }
      } else if(c.state==="type"){
        const n=Math.min(c.target.length,Math.floor((now-c.t0)/TYPE_MS)+1);
        c.name.textContent=c.target.slice(0,n);
        if(n>=c.target.length){
          c.cur=c.target; c.state="idle";
          c.el.classList.remove("typing");
        }
      }
    }
  }

  /* ================================================================ */
  /* Haupt-Loop                                                       */
  /* ================================================================ */
  function inView(rect){ return rect.bottom>-window.innerHeight*0.5 && rect.top<window.innerHeight*1.5; }
  function tick(now){
    /* Teardown-Guard: nach Soft-Navigation (App Router) ist die Szene aus dem
       Dokument entfernt -> Loop beenden statt ewig gegen detached DOM laufen. */
    if(!sceneMain.isConnected){ return; }
    const vh=window.innerHeight;
    const mr=sceneMain.getBoundingClientRect();
    if(inView(mr)){
      const Pm=clamp((-mr.top)/(mr.height-vh),0,1);
      applyMain(Pm);
    }
    const br=sceneBelief.getBoundingClientRect();
    if(inView(br)){
      const bp=clamp((-br.top)/(br.height-vh),0,1);
      applyBelief(bp);
      // FIX2: Sobald die Belief-Sektion einblendet (bp>0), den Kopf ausblenden.
      // Der Kopf ist an diesem Punkt bereits (fast) vollstaendig zerfallen und aus
      // dem Bild geflogen (Pm>=0.97); sein Aufbau + Zerfall in der Story-Sektion
      // (bp==0) bleibt unberuehrt und voll deckend. Das verhindert, dass restliche
      // wegfliegende Fragmente in die zentrierten Statements hineinragen.
      const g=clamp(bp/0.04,0,1);
      if(g>=1){ headSvg.style.display="none"; }
      else{ headSvg.style.display=""; headSvg.style.opacity=((parseFloat(headSvg.style.opacity)||0)*(1-g)).toFixed(3); }
    } else {
      headSvg.style.display="";
    }
    partnerTick(now);
    requestAnimationFrame(tick);
  }

  /* ================================================================ */
  /* Boot                                                             */
  /* ================================================================ */
  function boot(){
    initCells();
    computeShifts();
    fitMask();
    placeUeDots();
    measureStory();
    measureHeadStarts();
    measureStmts();
    /* Font-Timing: boot laeuft oft VOR dem DM-Sans-Load -> Titel-Fit/Ue-Punkte
       messen mit Fallback-Font (Titel leicht beschnitten, Punkte falsch/fehlend).
       Nach fonts.ready einmal komplett nachmessen (idempotent, wie Resize). */
    if(document.fonts&&document.fonts.ready){
      document.fonts.ready.then(function(){
        computeShifts(); fitMask(); placeUeDots();
        measureStory(); measureHeadStarts(); measureStmts();
      });
    }

    if(reduced){
      sticky.setAttribute("data-active","0");
      htitle.style.transform="none";
      renderHead(1,0);
      headSvg.style.opacity="1";
      textMove.style.transform="none";
      for(const b of textMoveBlocks) b.style.opacity="1";
      for(const st of stmts){ st.style.transform="none"; st.style.opacity="1"; }
      bCta.style.opacity="1"; bCta.style.transform="none"; bCta.style.pointerEvents="auto";
      return;
    }

    initFluid();
    if(autobtn) autobtn.addEventListener("click",()=>runAuto(autobtn));
    if(noHover){
      const autoLoop=()=>{
        if(!sceneMain.isConnected){ return; }
        if(painting&&!autoRunning&&document.visibilityState==="visible"&&window.scrollY<window.innerHeight*0.3){ runAuto(autobtn); }
        setTimeout(autoLoop,9000);
      };
      setTimeout(autoLoop,1400);
    }

    renderHead(0,0);
    headSvg.style.opacity="1";
    applyMain(0);
    /* Deck-Maske erst JETZT scharf schalten (data-active=0 im HTML): das
       masksvg ist sicher geparst, die Maske startet voll deckend (weisser
       mrect, keine Blobs) -> kein Navy-Flash beim Laden, Malen wie gehabt. */
    sticky.setAttribute("data-active","1");
    requestAnimationFrame(tick);
  }

  let rz;
  const onRz=()=>{
    if(!sceneMain.isConnected){ window.removeEventListener("resize",onRz); return; }
    clearTimeout(rz);
    rz=setTimeout(()=>{
      computeShifts(); fitMask(); placeUeDots(); measureStory(); measureHeadStarts(); measureStmts();
    },150);
  };
  window.addEventListener("resize",onRz);

  // Schluss-CTA: sanftes Scroll-Reveal
  const ctaInner=document.getElementById("ctaInner");
  if(ctaInner){
    if(reduced){ ctaInner.classList.add("on"); }
    else if("IntersectionObserver" in window){
      const io=new IntersectionObserver(es=>{
        es.forEach(e=>{ if(e.isIntersecting){ ctaInner.classList.add("on"); io.disconnect(); } });
      },{threshold:0.35});
      io.observe(ctaInner);
    } else { ctaInner.classList.add("on"); }
  }

  /* ================================================================ */
  /* K12 — ">>" aus roten Zahnrad-Fragmenten (comp1), setzt sich beim   */
  /*        Einscrollen der Partner-Sektion zusammen                    */
  /* ================================================================ */
  const chevWrap=document.getElementById("chevWrap");
  const pCta=document.getElementById("pCta");
  const ARM="M9.75 16.66 C9.75 23.0 10.94 24.12 12.05 25.23 C13.16 26.43 14.17 26.77 14.77 27.28 C14.77 27.28 14.77 27.45 14.77 27.45 C14.77 27.45 7.62 27.45 7.62 27.45 C-2.17 27.45 -9.23 22.74 -9.15 10.49 C-9.15 10.49 -9.15 -9.64 -9.15 -9.64 C-9.15 -20.86 -10.51 -26.0 -14.77 -27.2 C-14.77 -27.2 -14.77 -27.45 -14.77 -27.45 C1.32 -27.02 9.75 -21.63 9.75 -8.78 C9.75 -8.78 9.75 16.66 9.75 16.66 Z";
  const WEDGE1="M-17.8 -16.06 C-17.8 -16.06 -17.8 -16.99 -17.8 -16.99 C-1.01 -14.58 5.81 -13.08 17.8 -17.54 C17.8 -17.54 17.8 17.54 17.8 17.54 C17.8 17.54 16.33 17.54 16.33 17.54 C9.69 3.25 -1.56 -11.05 -17.8 -16.06 Z";
  const WEDGE2="M-17.25 -17.54 C-17.25 -17.54 -15.77 -17.54 -15.77 -17.54 C-9.31 -3.8 2.86 10.12 17.25 15.13 C17.25 15.13 17.25 16.06 17.25 16.06 C-1.02 13.09 -9.69 12.9 -17.25 17.54 C-17.25 17.54 -17.25 -17.54 -17.25 -17.54 Z";
  // C9: grosses ">>" aus GENAU 4 Teilen (viewBox 0 0 128 64) — pro ">" zwei
  // Zahnrad-Arme: oben-diagonal + unten-diagonal, treffen sich an der rechten Spitze.
  // R7: die zwei OBEREN Arme werden horizontal gespiegelt (fx:-1), damit ihre Enden
  // sauber an die Enden der unteren Arme anschliessen und jedes ">" eine geschlossene
  // Chevron-Form bildet (Spitzen treffen sich).
  const CHEV=[
    {d:ARM, cx:40,cy:19,rot:-54,sc:.62,fx:-1},   // Chevron 1 oben (gespiegelt)
    {d:ARM, cx:40,cy:45,rot: 54,sc:.62,fx: 1},   // Chevron 1 unten
    {d:ARM, cx:86,cy:19,rot:-54,sc:.62,fx:-1},   // Chevron 2 oben (gespiegelt)
    {d:ARM, cx:86,cy:45,rot: 54,sc:.62,fx: 1}    // Chevron 2 unten
  ];
  const chevFrags=[];
  if(chevWrap){
    CHEV.forEach((c,i)=>{
      const p=document.createElementNS(SVGNS,"path");
      p.setAttribute("class","chev-frag");
      p.setAttribute("d",c.d);
      c.home="translate("+c.cx+"px,"+c.cy+"px) rotate("+c.rot+"deg) scale("+(c.fx*c.sc)+","+c.sc+")";
      const sdx=34+(i%3)*6, sdy=(i%2?1:-1)*12;
      c.scat="translate("+(c.cx+sdx)+"px,"+(c.cy+sdy)+"px) rotate("+(c.rot+150)+"deg) scale("+(c.fx*c.sc*0.5)+","+(c.sc*0.5)+")";
      p.style.transform=c.scat;
      chevWrap.appendChild(p);
      chevFrags.push(p);
    });
  }
  let chevDone=false;
  function assembleChev(){
    if(chevDone) return; chevDone=true;
    chevFrags.forEach((p,i)=>{
      p.style.transitionDelay=(i*70)+"ms";
      p.style.transform=CHEV[i].home;
      p.style.opacity="1";
    });
  }
  if(reduced){ chevFrags.forEach((p,i)=>{p.style.transform=CHEV[i].home;p.style.opacity="1";}); }
  else if(pCta && "IntersectionObserver" in window){
    const io=new IntersectionObserver(es=>{es.forEach(e=>{ if(e.isIntersecting){ assembleChev(); io.disconnect(); } });},{threshold:0.5});
    io.observe(pCta);
  } else { assembleChev(); }

  /* ================================================================ */
  /* C10 — FAQ: pro Frage faehrt eine Hairline von links nach rechts    */
  /*        ein, die Frage blendet mit ihr auf (details/summary bleibt) */
  /* ================================================================ */
  const faqItems=[...document.querySelectorAll(".scene-faq .faq-item")];
  if(reduced){ faqItems.forEach(f=>f.classList.add("revealed")); }
  else if("IntersectionObserver" in window){
    const fio=new IntersectionObserver((es)=>{es.forEach(e=>{
      if(e.isIntersecting){ e.target.classList.add("revealed"); fio.unobserve(e.target); }
    });},{threshold:0.25,rootMargin:"0px 0px -8% 0px"});
    faqItems.forEach(f=>fio.observe(f));
  } else { faqItems.forEach(f=>f.classList.add("revealed")); }

  /* ================================================================ */
  /* K13 — Footer-Wortmarke setzt sich beim Eintritt zusammen (verein-  */
  /*        fachte Reassembly)                                          */
  /* ================================================================ */
  const rrFoot=document.getElementById("rrFoot");
  if(rrFoot){
    if(reduced){ rrFoot.classList.add("in"); }
    else if("IntersectionObserver" in window){
      const io=new IntersectionObserver(es=>{es.forEach(e=>{ if(e.isIntersecting){ rrFoot.classList.add("in"); io.disconnect(); } });},{threshold:0.25});
      io.observe(document.getElementById("rrFootWord")||rrFoot);
    } else { rrFoot.classList.add("in"); }
  }

  if(document.fonts && document.fonts.ready){ document.fonts.ready.then(boot); }
  else { window.addEventListener("load",boot); }

  /* K11: Verifikation, dass die Partner-Namen wirklich in DM Sans rendern */
  window.__diag={pieces:P.length,
    get dmsans(){ return !!(document.fonts && document.fonts.check && document.fonts.check('600 24px "DM Sans"')); },
    get sT(){return sT;}, get paintMaxY(){return paintMaxY;}, get tyCut(){return tyCut;}};
})();
